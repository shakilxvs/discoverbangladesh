rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Single-admin gate for now (NEXT_PUBLIC_ADMIN_EMAIL). Works for both
    // sign-in methods: password auth already requires knowing the password,
    // and Google auth already requires owning that Google account, so no
    // extra verification checks are layered on top here.
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'shakilxvs@gmail.com';
    }

    match /spots/{spotId} {
      allow read: if resource.data.visibility == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subCategories/{subCategoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /districts/{districtId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Comments (which also carry the 1-5 star rating) are public to create —
    // "automatically approved, no moderation queue" per spec — but validated
    // on write, and only admin can hide/delete/lock.
    match /comments/{commentId} {
      allow read: if resource.data.hidden != true || isAdmin();
      allow create: if request.resource.data.spotId is string
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() < 80
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && (!('text' in request.resource.data) || request.resource.data.text.size() < 2000)
        && (!('hidden' in request.resource.data) || request.resource.data.hidden == false);
      allow update, delete: if isAdmin();
    }
  }
}
